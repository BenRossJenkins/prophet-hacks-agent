# Anthropic — primary LLM forecaster
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — second vendor in the ensemble
OPENAI_API_KEY=sk-proj-...

# Google Gemini — third vendor in the ensemble
GEMINI_API_KEY=AIza...

# Prophet Arena server. Auth via X-API-Key header (prophet_...).
# Endpoints: GET /forecast/events, GET /forecast/scores, GET /health.
PA_SERVER_URL=https://api.aiprophet.dev
PA_SERVER_API_KEY=
PA_TEAM_NAME=

# Optional: model override for the single-model forecast path
FORECAST_MODEL=claude-opus-4-7

# Optional: where the production agent writes its prediction log
PREDICTION_LOG_PATH=data/predictions.jsonl

# Optional: GCS URI for the calibration table. When set, the live agent
# fetches the table from GCS (with 60s cache), so daily refits pushed
# by the local script flow into Cloud Run without a redeploy.
CALIBRATION_GCS_URI=gs://prophet-hacks-2026-calibration/calibration.json

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.brierpatch.daily-calibration</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>/Users/benjenkins/Documents/AI FORECASTING HACKATHON/scripts/daily_calibration.sh</string>
  </array>

  <key>StartCalendarInterval</key>
  <dict>
    <!-- 6:00 AM local time, every day -->
    <key>Hour</key>
    <integer>6</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/benjenkins/Documents/AI FORECASTING HACKATHON/data/calibration-cron.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/benjenkins/Documents/AI FORECASTING HACKATHON/data/calibration-cron.log</string>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
